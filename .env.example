# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (for bot protection)
# Get these from Cloudflare dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# IndexNow (search engine URL submission)
# Key must match the filename in /public/<key>.txt
INDEXNOW_KEY=28f9d924a9656ca1dd32c0c3dd6acb00

# PostgreSQL — Drizzle ORM (for chai_sample_orders table)
# Use Supabase's "Transaction" pooler URL (port 6543) for serverless/edge environments
# Found at: https://app.supabase.com/project/_/settings/database → Connection string → URI
DATABASE_URL=

# Supabase Configuration (for bulk_chai_price_quotes table — existing quote form)
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (for bot protection)
# Get these from Cloudflare dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cashfree Payments (for /buy-chai order flow)
# Get these from Cashfree dashboard: https://merchant.cashfree.com/merchants/developers
# Use sandbox keys (TEST_*) for development, live keys for production
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

# Site URL (used for Cashfree return_url after payment)
NEXT_PUBLIC_SITE_URL=https://www.bulkchai.com

# IndexNow (search engine URL submission)
# Key must match the filename in /public/<key>.txt
INDEXNOW_KEY=28f9d924a9656ca1dd32c0c3dd6acb00
